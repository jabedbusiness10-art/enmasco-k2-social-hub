{
  "name": "enmasco-k2-social-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node -r dotenv/config ./node_modules/next/dist/bin/next dev",
    "messenger:ws": "tsx server/messenger-socket.mts",
    "build": "prisma generate && next build",
    "start": "node -r dotenv/config ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "worker": "cross-env ROLE=worker tsx server/queue-worker.ts",
    "scheduler": "cross-env ROLE=scheduler tsx server/scheduler.ts",
    "validate:env": "tsx -e \"import('./lib/env/validate').then(m=>{const r=m.validateEnv(); if(!r.ok) process.exit(1);})\"",
    "test:task75": "tsx --test tests/task75/*.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "bullmq": "^5.80.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.14",
    "openai": "^4.104.0",
    "pg": "^8.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.81.0",
    "recharts": "^2.15.4",
    "shadcn": "^4.13.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5.4.0"
  }
}
