// ===========================================================================
// TASK-57 — Enterprise Background Queue Engine (BullMQ + Redis) — audit models
// BullMQ is the source of truth for live job processing; these tables provide
// durable, queryable history + monitoring (independent of Redis retention).
// ===========================================================================

model QueueJob {
  id          String      @id @default(cuid())
  queue       String // e.g. "publish", "ai", "notification", "token" ...
  name        String // job type, e.g. "facebook-publish"
  jobId       String // BullMQ job id (when Redis-backed)
  payload     String // JSON (serialized args), encrypted if sensitive
  status      QueueJobStatus @default(WAITING)
  priority    Int         @default(0)
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  progress    Int         @default(0)
  lastError   String?
  result      String? // JSON result summary
  startedAt   DateTime?
  finishedAt  DateTime?
  processingMs Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  retries     RetryHistory[]

  @@index([queue])
  @@index([status])
  @@index([createdAt])
  @@index([jobId])
}

model QueueWorker {
  id           String   @id @default(cuid())
  name         String // worker instance name
  queue        String
  pid          Int
  status       WorkerStatus @default(IDLE)
  startedAt    DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  jobsProcessed Int      @default(0)
  jobsFailed   Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model WorkerHeartbeat {
  id        String   @id @default(cuid())
  workerId  String
  queue     String
  status    WorkerStatus
  cpu       Float?
  memoryMb  Float?
  timestamp DateTime @default(now())

  @@index([workerId])
  @@index([timestamp])
}

model QueueMetric {
  id        String   @id @default(cuid())
  queue     String
  metric    String // waiting | active | completed | failed | delayed
  value     Int
  timestamp DateTime @default(now())

  @@index([queue])
  @@index([metric])
  @@index([timestamp])
}

model FailedJob {
  id          String   @id @default(cuid())
  queue       String
  name        String
  jobId       String?
  payload     String?
  error       String
  attempts    Int
  failedAt    DateTime @default(now())
  recoveredAt DateTime?

  @@index([queue])
  @@index([failedAt])
}

model RetryHistory {
  id          String   @id @default(cuid())
  jobId       String
  queue       String
  attempt     Int
  error       String?
  retriedAt   DateTime @default(now())

  job QueueJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ============================================================================
// TASK-62 — Enterprise Security Audit & Role-Based Permissions
// Additive models. DB-driven RBAC complements the static ROLE_PERMISSIONS map
// in services/auth/permissions.ts (merged at runtime by lib/security/permissions.ts).
// ============================================================================

/// Permission catalog (the universe of grantable permissions).
model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. VIEW_DASHBOARD, MEDIA_DELETE
  category    String   // DASHBOARD | SOCIAL | MEDIA | ... | SECURITY
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

/// Per-role permission grants (allow/deny) — overrides/extends static defaults.
model RolePermission {
  id         String   @id @default(cuid())
  role       UserRole
  permission String
  access     String   @default("ALLOW") // ALLOW | DENY
  createdAt  DateTime @default(now())

  permissionRef Permission? @relation(fields: [permission], references: [name])

  @@unique([role, permission])
  @@index([role])
  @@index([permission])
}

/// Optional additional roles for a user (primary role remains User.role).
model UserRoleLink {
  id        String   @id @default(cuid())
  userId    String
  role      UserRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

/// Per-user permission override (fine-grained, on top of role grants).
model UserPermissionOverride {
  id         String   @id @default(cuid())
  userId     String
  permission String
  access     String   @default("ALLOW") // ALLOW | DENY
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
}

/// API access log (every authenticated /api/* call is recorded by middleware).
model ApiAccessLog {
  id           String   @id @default(cuid())
  endpoint     String
  method       String
  statusCode   Int
  executionMs  Int?
  userId       String?
  userEmail    String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([endpoint])
  @@index([statusCode])
  @@index([createdAt])
}

/// Login / logout / session history per user.
model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  email     String
  result    String   // SUCCESS | FAILURE | LOGOUT | EXPIRED | BLOCKED
  ip        String?
  userAgent String?
  browser   String?
  os        String?
  country   String?
  city      String?
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([result])
  @@index([createdAt])
}

/// Security events timeline (critical/high/medium/low).
model SecurityEvent {
  id        String   @id @default(cuid())
  severity  String   // CRITICAL | HIGH | MEDIUM | LOW
  type      String   // PERMISSION_CHANGED | SUSPICIOUS_LOGIN | ...
  title     String
  message   String?
  userId    String?
  userEmail String?
  ip        String?
  metadata  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([severity])
  @@index([type])
  @@index([resolved])
  @@index([createdAt])
}

/// Trusted devices for 2FA-ready device management.
model TrustedDevice {
  id           String   @id @default(cuid())
  userId       String
  fingerprint  String
  name         String?
  browser      String?
  os           String?
  ip           String?
  lastUsedAt   DateTime @default(now())
  trustedAt    DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
}

/// Blocked IPs (auto or manual).
model BlockedIP {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  source    String   @default("MANUAL") // MANUAL | AUTO
  blockedBy String?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([ip])
}

/// Password policy (single active row; 2FA-ready flags).
model PasswordPolicy {
  id                  String   @id @default(cuid())
  minLength           Int      @default(8)
  requireUppercase    Boolean  @default(true)
  requireLowercase    Boolean  @default(true)
  requireNumber       Boolean  @default(true)
  requireSpecial      Boolean  @default(false)
  expirationDays      Int?     // null = never
  historyCount        Int      @default(0) // 2FA-ready: password history depth
  twoFactorEnabled    Boolean  @default(false) // 2FA-ready (infra only, not forced)
  twoFactorMethods    String   @default("AUTHENTICATOR,EMAIL_OTP,RECOVERY_CODES") // 2FA-ready
  active              Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  updatedById         String?
}

// ============================================================================
// TASK-63 — Enterprise Backup & Disaster Recovery
// Additive models. Real backup jobs, snapshots, schedules, storage, restores.
// ============================================================================

model BackupJob {
  id              String   @id @default(cuid())
  name            String
  type            String   // DATABASE | MEDIA | USER | ANALYTICS | QUEUE | NOTIFICATION | CONFIG | SETTINGS
  mode            String   @default("MANUAL") // MANUAL | SCHEDULED | INCREMENTAL | FULL
  status          String   @default("QUEUED") // QUEUED | RUNNING | COMPLETED | FAILED | VERIFYING
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs       Int?
  sizeBytes       Int?
  compressionRatio Float?
  checksum        String?
  storageProvider String   @default("LOCAL") // LOCAL | S3 | R2 | AZURE | GCS | B2
  storagePath     String?
  queueJobId      String?  // BullMQ job id when Redis-backed
  createdById     String?
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  metadata        Json?
  error           String?
  scheduleId      String?
  createdAt       DateTime @default(now())

  schedule        BackupSchedule? @relation(fields: [scheduleId], references: [id])
  snapshots       BackupSnapshot[]
  verifications   BackupVerification[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model BackupSnapshot {
  id          String   @id @default(cuid())
  backupJobId String
  type        String
  path        String?
  sizeBytes   Int?
  checksum    String?
  createdAt   DateTime @default(now())

  backupJob   BackupJob @relation(fields: [backupJobId], references: [id], onDelete: Cascade)

  @@index([backupJobId])
}

model BackupSchedule {
  id            String   @id @default(cuid())
  name          String
  type          String   // backup type to run
  frequency     String   // HOURLY | DAILY | WEEKLY | MONTHLY | CUSTOM
  cron          String?  // custom cron expression
  enabled       Boolean  @default(true)
  paused        Boolean  @default(false)
  retentionCount Int      @default(7)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs          BackupJob[]

  @@index([enabled])
  @@index([nextRunAt])
}

model BackupStorage {
  id           String   @id @default(cuid())
  provider     String   @default("LOCAL") // LOCAL | S3 | R2 | AZURE | GCS | B2
  configured   Boolean  @default(false)
  totalBytes   Int      @default(0)
  usedBytes    Int      @default(0)
  availableBytes Int    @default(0)
  bucket       String?  // bucket/container name (never secrets)
  region       String?
  updatedAt    DateTime @updatedAt
}

model RestoreJob {
  id           String   @id @default(cuid())
  backupJobId  String
  scope        String   // DATABASE | MEDIA | SETTINGS | EVERYTHING
  status       String   @default("QUEUED") // QUEUED | RUNNING | COMPLETED | FAILED
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  requestedById String?
  report       Json?
  error        String?
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([backupJobId])
}

model RecoveryLog {
  id           String   @id @default(cuid())
  type         String   // BACKUP_CREATED | BACKUP_FAILED | BACKUP_VERIFIED | RESTORE_STARTED | RESTORE_COMPLETED | RESTORE_FAILED | VERIFICATION_FAILED | STORAGE_WARNING
  message      String
  severity     String   @default("INFO") // INFO | WARNING | CRITICAL
  backupJobId  String?
  restoreJobId String?
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
}

model BackupRetentionPolicy {
  id             String   @id @default(cuid())
  keepLast       Int      @default(7)
  archiveCritical Boolean @default(true)
  autoCleanup    Boolean  @default(true)
  active         Boolean  @default(true)
  updatedById    String?
  updatedAt      DateTime @updatedAt
}

model BackupVerification {
  id               String   @id @default(cuid())
  backupJobId      String
  status           String   // PASSED | FAILED
  checksumExpected String?
  checksumActual   String?
  details          String?
  verifiedAt       DateTime @default(now())

  backupJob        BackupJob @relation(fields: [backupJobId], references: [id], onDelete: Cascade)

  @@index([backupJobId])
  @@index([status])
}

// TASK-66B — Real persistence for the Team > Members module.
// Dedicated table so employee records survive refresh and are independent
// of the auth User table (no impact on auth/RBAC).
enum MemberStatus {
  ACTIVE
  AWAY
  OFFLINE
}

model TeamMember {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  department  String?
  role        String?
  status      MemberStatus @default(ACTIVE)
  avatar      String?
  teamId      String?
  companyId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team    Team?    @relation("TeamContacts", fields: [teamId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([department])
  @@index([teamId])
  @@index([companyId])
}

// ===========================================================================
// TASK-70 — Enterprise Database Foundation
// Adds the remaining production tables (Team, DraftPost, AIJob, ActivityLog,
// ApiConnection, PostAnalytics) + relations, without touching existing models.
// All new columns are nullable or on new tables → non-destructive migration.
// ===========================================================================

enum TeamStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum DraftStatus {
  DRAFT
  IN_REVIEW
  READY
  ARCHIVED
}

enum AIJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ApiConnStatus {
  ACTIVE
  INACTIVE
  REVOKED
  ERROR
}

/// Teams belong to a Company and group Users (and TeamMember contacts).
model Team {
  id          String     @id @default(cuid())
  companyId   String
  ownerId     String?
  name        String
  slug        String     @unique
  description String?
  status      TeamStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner       User?       @relation("TeamOwnership", fields: [ownerId], references: [id], onDelete: SetNull)
  members     User[]      @relation("TeamMembers")
  contacts    TeamMember[] @relation("TeamContacts")
  draftPosts  DraftPost[]

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
  @@index([slug])
  @@index([createdAt])
}

/// Draft posts — distinct from published Post; may later become a Post.
model DraftPost {
  id          String      @id @default(cuid())
  teamId      String?
  authorId    String
  title       String?
  content     String?
  platforms   Platform[]
  tags        String[]    @default([])
  mediaUrls   String[]    @default([])
  status      DraftStatus @default(DRAFT)
  postId      String?     @unique
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  team    Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  author  User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post    Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

/// AI jobs — generation / automation tasks queued against the AI provider.
model AIJob {
  id          String      @id @default(cuid())
  userId      String?
  type        String
  model       String?
  prompt      String?     @db.Text
  status      AIJobStatus @default(PENDING)
  result      String?     @db.Text
  error       String?
  tokensUsed  Int         @default(0)
  durationMs  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

/// Canonical activity log (distinct from AuditLog which is security-scoped).
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

/// External API connections / integrations (keys managed out-of-band).
model ApiConnection {
  id          String       @id @default(cuid())
  userId      String?
  name        String
  provider    String
  status      ApiConnStatus @default(ACTIVE)
  maskedKey   String?
  baseUrl     String?
  scopes      String[]     @default([])
  lastUsedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

/// Per-post analytics snapshot (satisfies Post ── Analytics relation).
model PostAnalytics {
  id          String   @id @default(cuid())
  postId      String
  platform    Platform?
  impressions Int      @default(0)
  engagements Int      @default(0)
  clicks      Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  recordedAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([platform])
  @@index([recordedAt])
}
