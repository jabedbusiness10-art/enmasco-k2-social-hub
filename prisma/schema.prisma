generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CEO
  ADMIN
  MARKETING_MANAGER
  MARKETING_TEAM
  CONTENT_CREATOR
  ANALYST
  VIEWER
}

enum DepartmentName {
  MARKETING
  SALES
  HR
  FINANCE
  IT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PostStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  APPROVED
  REJECTED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  X
  WEBSITE
}

enum WorkflowStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model OnlinePresence {
  userId     String        @id
  status     PresenceStatus @default(ONLINE)
  lastSeen   DateTime      @default(now())
  socketId   String?
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id        String   @id @default(cuid())
  name      UserRole @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Department {
  id          String          @id @default(cuid())
  name        DepartmentName  @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  users User[]
  assignments Assignment[] // TASK-53
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  username      String?   @unique
  password      String
  role          Role      @relation(fields: [roleId], references: [id])
  roleId        String
  department    Department? @relation(fields: [departmentId], references: [id])
  departmentId  String?
  teamId        String?
  avatar        String?
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // TASK-65 — i18n / localization preferences
  language      String   @default("en")
  timezone      String   @default("UTC")
  locale        String?  @default("en")

  posts         Post[]
  notifications Notification[]
  notificationReads NotificationRead[]
  notificationArchives NotificationArchive[]
  notificationPreferences NotificationPreference[]
  auditLogs     AuditLog[]
  conversations AIConversation[]
  scheduledPosts ScheduledPost[]
  workflowJobs  WorkflowJob[]
  aiPrompts     AIPrompt[]
  aiTokenUsages AITokenUsage[]
  mediaAssets   MediaAsset[]
  conversationMembers ConversationMember[]
  conversationNotifications ConversationNotification[]
  assignedConversations ConversationAssignment[] @relation("AssignmentTo")
  createdAssignments     ConversationAssignment[] @relation("AssignmentBy")
  presence     OnlinePresence?

  // TASK-53 relations
  assignedByAssignments   Assignment[] @relation("AssignedBy")
  assignedToAssignments   Assignment[] @relation("AssignedTo")
  assignmentComments      AssignmentComment[]
  assignmentActivities    AssignmentActivity[]

  accounts      Account[]
  sessions      Session[]

  // TASK-62 security relations
  userExtraRoles     UserRoleLink[]
  userPermOverride  UserPermissionOverride[]
  userLoginHistory  LoginHistory[]
  userTrustedDevices TrustedDevice[]

  // TASK-70 — enterprise foundation relations
  team          Team?       @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  ownedTeams    Team[]      @relation("TeamOwnership")
  draftPosts    DraftPost[]
  aiJobs        AIJob[]
  activityLogs  ActivityLog[]
  apiConnections ApiConnection[]

  @@index([roleId])
  @@index([departmentId])
  @@index([teamId])
  @@index([status])
  @@index([username])
  @@index([createdAt])
}

model CompanySettings {
  id              String   @id @default(cuid())
  companyId       String?  @unique // TASK-45 pre-flight: loose link to Company model (1:1)
  company         Company? @relation(fields: [companyId], references: [id])
  companyName     String
  companyShortName String?
  logoUrl         String?
  website         String?
  email           String?
  phone           String?
  address         String?
  timezone        String   @default("UTC")
  language        String   @default("en")
  dateFormat      String   @default("DD/MM/YYYY")
  timeFormat      String   @default("24H")
  theme           String   @default("dark")
  accentColor     String   @default("blue")
  sidebarStyle    String   @default("glass")
  glassEffect     Boolean  @default(true)
  sessionTimeout  Int      @default(30)
  passwordPolicy  String   @default("standard")
  auditLogging    Boolean  @default(true)
  supportEmail    String?
  defaultLanguage String   @default("en")
  allowRegistration Boolean @default(true)
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CompanySocialAccount {
  id             String    @id @default(cuid())
  platform       Platform
  accountName    String
  accountHandle  String?
  accountId      String?
  profileUrl     String?
  pageId         String?
  username       String?

  // Encrypted at rest (AES-256-GCM via lib/crypto). Stored as ciphertext strings.
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?

  // --- TASK-45 Meta OAuth extensions (all nullable, non-destructive) ---
  // Instagram Business account linked to the connected Facebook Page.
  instagramBusinessId String?
  // Display name of the selected Facebook Page.
  pageName            String?
  // Granted permission scopes (from token debug / granted_scopes).
  permissions         String[] @default([])
  // High-level token health derived from expiry + debug: ACTIVE | EXPIRED | EXPIRING
  accessTokenStatus   String?  @map("access_token_status")
  // OAuth provider that established this connection (meta | manual | linkedin | ...).
  provider            String?  @default("manual")

  // --- TASK-46 LinkedIn OAuth extensions (all nullable, non-destructive) ---
  // Linkedin Organization (Company Page) identifiers + metadata.
  organizationId    String?  // LinkedIn organization / company page urn id
  organizationName  String?  // display name of the organization
  companyName       String?  // human-readable company name (alias of organizationName)
  companyLogo       String?  // logo URL from LinkedIn
  apiVersion        String?  // LinkedIn API version used (e.g. "202504")
  // -------------------------------------------------------------------------

  status         PlatformStatus @default(CONNECTED)
  connectedBy    String
  connectedById  String?
  lastSyncAt     DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts Post[]

  @@unique([platform, accountHandle])
  @@index([platform])
  @@index([isActive])
}

enum PlatformStatus {
  CONNECTED
  EXPIRING_SOON
  DISCONNECTED
  PERMISSION_ERROR
}

// ===========================================================================
// TASK-47 — Website ↔ Social Hub Integration
// ===========================================================================

enum CmsType {
  WORDPRESS
  NEXTJS
  CUSTOM
  HEADLESS
  LARAVEL
  STATIC
}

enum WebsiteStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

model WebsiteConnection {
  id            String   @id @default(cuid())
  companyId     String?
  websiteName   String
  websiteUrl    String
  cmsType       CmsType  @default(CUSTOM)
  // Encrypted at rest (AES-256-GCM via lib/crypto). Stored as ciphertext.
  apiKey        String
  webhookSecret String
  status        WebsiteStatus @default(CONNECTED)
  // Health signals (live, recomputed on test/status).
  online        Boolean  @default(true)
  sslValid      Boolean  @default(true)
  apiStatus     Boolean  @default(true)
  webhookStatus Boolean  @default(true)
  lastSync      DateTime?
  syncFrequency String   @default("MANUAL") // MANUAL | HOURLY | DAILY | REALTIME
  connectedBy   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

enum MediaStatus {
  ACTIVE
  ARCHIVED
  TRASHED
}

model MediaFolder {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  icon      String? // lucide icon name
  parentId  String?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  parent    MediaFolder? @relation("FolderChildren", fields: [parentId], references: [id])
  children  MediaFolder[] @relation("FolderChildren")
  assets    MediaAsset[]

  @@index([parentId])
}

model MediaAsset {
  id            String      @id @default(cuid())
  fileName      String
  originalName  String
  fileType      String // IMAGE | VIDEO | DOCUMENT | LOGO | BRAND_ASSET
  mimeType      String
  fileSize      Int
  cloudinaryId  String // storage key / provider id (Cloudinary/S3 ready)
  url           String
  width         Int?
  height        Int?
  duration      Float? // seconds, for video/audio
  extension     String? // jpg, mp4, pdf ...
  category      String?
  tags          String[]
  description   String?
  status        MediaStatus @default(ACTIVE)
  favorited     Boolean     @default(false)
  usageCount    Int         @default(0)
  lastUsedAt    DateTime?
  uploadedBy    String
  uploadedById  String?
  folderId      String?
  platforms     String[]    @default([]) // facebook, instagram, linkedin, youtube, x
  campaign      String?
  aiGenerated   Boolean     @default(false)
  scheduledPosts Json?       // [{platform, scheduledAt, postId}]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  archivedAt    DateTime?

  folder      MediaFolder? @relation(fields: [folderId], references: [id])
  uploadedUser User?       @relation(fields: [uploadedById], references: [id])
  activities  MediaActivity[]

  versions    MediaVersion[]
  shares      MediaShare[]
  metadata    MediaMetadata[]

  collectionItems CollectionItem[]
  relationships    MediaRelationship[]
  favorites        MediaFavorite[]
  usages           MediaUsage[]
  history          MediaHistory[]
  labels           MediaLabel[]
  assetTags        MediaAssetTag[]
  archives         MediaArchive[]

  @@index([fileType])
  @@index([category])
  @@index([folderId])
  @@index([status])
  @@index([uploadedById])
  @@index([createdAt])
}

model MediaActivity {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  userName  String
  action    String // UPLOAD | RENAME | DELETE | MOVE | DOWNLOAD | SHARE | ARCHIVE | RESTORE | FAVORITE
  meta      String? // free text / extra info
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([createdAt])
}

// ---- TASK-54: additional DAM models (architecture-ready) ----
model MediaTag {
  id     String   @id @default(cuid())
  name   String   @unique
  color  String?  // hex for UI badge
  createdAt DateTime @default(now())

  assetTags MediaAssetTag[]
}

// Normalized many-to-many: asset <-> tag (TASK-56)
model MediaAssetTag {
  id        String   @id @default(cuid())
  assetId   String
  tagId     String
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   MediaTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@index([assetId])
  @@index([tagId])
  @@unique([assetId, tagId])
}

// Archive records (TASK-56): soft-archive with restore support
model MediaArchive {
  id        String   @id @default(cuid())
  assetId   String
  reason    String?
  archivedBy String
  restoredAt DateTime?
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
}

model MediaVersion {
  id        String   @id @default(cuid())
  assetId   String
  version   Int      @default(1)
  fileName  String
  fileSize  Int
  url       String
  note      String?
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
}

model MediaShare {
  id        String   @id @default(cuid())
  assetId   String
  token     String   @unique
  createdById String
  expiresAt DateTime?
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
  @@index([token])
}

model MediaCollection {
  id          String   @id @default(cuid())
  name        String
  description String?
  parentId    String?  // TASK-55: nested collections
  isPinned    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      MediaCollection? @relation("CollectionTree", fields: [parentId], references: [id])
  children    MediaCollection[] @relation("CollectionTree")
  items       CollectionItem[]

  @@index([parentId])
}

model MediaMetadata {
  id          String   @id @default(cuid())
  assetId     String
  width       Int?
  height      Int?
  duration    Float?
  mimeType    String?
  exif        String?  @db.Text // JSON, AI-label ready
  aiTags      String[] @default([])
  aiCaption   String?  @db.Text
  createdAt   DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
}

// ---- TASK-55: Media Tags & Collections (organization system) ----
model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  assetId      String
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  collection MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  asset      MediaAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([collectionId])
  @@index([assetId])
}

model MediaRelationship {
  id         String   @id @default(cuid())
  assetId    String
  context    String
  refId      String?
  refLabel   String?
  createdAt  DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
  @@index([context])
}

model MediaFavorite {
  id         String   @id @default(cuid())
  assetId    String
  userId     String
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([assetId])
}

model MediaUsage {
  id          String   @id @default(cuid())
  assetId     String
  context     String
  usedAt      DateTime @default(now())
  asset       MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
}

model MediaHistory {
  id        String   @id @default(cuid())
  assetId   String
  actorId   String
  action    String
  field     String?
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
}

model MediaLabel {
  id        String   @id @default(cuid())
  assetId   String
  label     String
  source    String   @default("MANUAL")
  confidence Float?
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId])
  @@index([label])
}
model Campaign {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String?
  budget      Float?
  createdById String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts Post[]
}

model Post {
  id            String    @id @default(cuid())
  content       String?
  mediaUrl      String?
  platform      Platform
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  campaignId    String?
  createdById   String
  accountId     String?
  tags          String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign   Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  account    CompanySocialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creator    User                 @relation(fields: [createdById], references: [id])
  scheduled  ScheduledPost?
  platforms  PostPlatform[]
  media      PostMedia[]
  jobs       PublishingJob[]
  history    PublishingHistory[]
  approvals  Approval[]
  analytics  PostAnalytics[]
  drafts     DraftPost[]

  // TASK-48 — composer fields
  title       String?
  link        String?
  cta         String?
  location    String?
  hashtags    String[] @default([])

  @@index([platform])
  @@index([status])
  @@index([campaignId])
  @@index([accountId])
  @@index([createdById])
  @@index([publishedAt])
  @@index([createdAt])
}

model ScheduledPost {
  id              String    @id @default(cuid())
  postId          String    @unique
  scheduledAt     DateTime
  priority        String?
  retryCount      Int       @default(0)
  lastError       String?
  status          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  owner           User?     @relation(fields: [ownerId], references: [id])
  ownerId         String?

  @@index([scheduledAt])
  @@index([status])
}

// ===========================================================================
// TASK-48 — Enterprise Real Publishing Engine
// ===========================================================================

enum PublishStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum JobState {
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  RETRY
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QueueState {
  QUEUED
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum QueueJobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
  DELAYED
  PAUSED
  STALLED
}

enum WorkerStatus {
  IDLE
  PROCESSING
  PAUSED
  OFFLINE
}

model PostPlatform {
  id           String       @id @default(cuid())
  postId       String
  platform     Platform // FACEBOOK | INSTAGRAM | LINKEDIN (also X/TIKTOK/YOUTUBE future)
  accountId    String? // CompanySocialAccount id (the connected page/company)
  status       PublishStatus @default(QUEUED)
  platformPostId String? // id returned by the platform after publish
  liveUrl      String? // permalink to the published post
  error        String?
  mediaIds     String[] // PostMedia ids used for this platform
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([postId])
  @@index([platform])
  @@index([status])
}

model PostMedia {
  id         String @id @default(cuid())
  postId     String
  type       String // IMAGE | VIDEO | CAROUSEL | DOCUMENT | LINK
  url        String
  thumbnail  String?
  alt        String?
  order      Int    @default(0)
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PublishingJob {
  id            String   @id @default(cuid())
  postId        String
  platform      Platform
  accountId     String?
  state         JobState @default(QUEUED)
  scheduledFor  DateTime? // when to publish (null = now)
  startedAt     DateTime?
  finishedAt    DateTime?
  attempt       Int      @default(0)
  maxAttempts   Int      @default(3)
  lastError     String?
  resultPostId  String?
  resultUrl     String?
  queueId       String? // links to Queue row (DB-backed or BullMQ job id)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([scheduledFor])
  @@index([postId])
}

model PublishingHistory {
  id           String   @id @default(cuid())
  postId       String
  platform     Platform
  accountId    String?
  status       PublishStatus
  postPlatformId String?
  publishedBy  String
  publishedAt  DateTime @default(now())
  platformPostId String?
  liveUrl      String?
  errorMessage String?
  jobId        String?
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([platform])
  @@index([status])
  @@index([publishedAt])
}

model Approval {
  id         String        @id @default(cuid())
  postId     String
  status     ApprovalStatus @default(PENDING)
  requestedBy String
  reviewedBy  String?
  reviewedAt  DateTime?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId])
  @@index([postId])
  @@index([status])
}

model Queue {
  id          String    @id @default(cuid())
  name        String // e.g. "publishing"
  payload     String // JSON (serialized job), encrypted if sensitive
  state       QueueState @default(QUEUED)
  priority    Int       @default(0)
  runAt       DateTime  @default(now()) // earliest run time (for scheduled)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  lockedUntil DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([state])
  @@index([runAt])
  @@index([name])
}

// ===========================================================================
// K2 MESSENGER  (TASK-44) — enums
// ===========================================================================

enum ConversationKind {
  DIRECT
  GROUP
  CHANNEL
  DEPARTMENT
  ANNOUNCEMENT
  CEO_BROADCAST
  COMPANY_BROADCAST
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  BUSY
  AWAY
  DND
}

enum MsgStatus {
  SENT
  DELIVERED
  READ
}

enum AttachmentKind {
  IMAGE
  VIDEO
  AUDIO
  PDF
  WORD
  EXCEL
  POWERPOINT
  ZIP
  OTHER
}

enum ReactionEmoji {
  LIKE
  HEART
  FIRE
  CLAP
  LAUGH
  WOW
  CRY
  PARTY
}

model Conversation {
  id          String          @id @default(cuid())
  kind        ConversationKind
  title       String?
  description String?
  avatarUrl   String?
  isPinned    Boolean         @default(false)
  isStarred   Boolean         @default(false)
  isArchived  Boolean         @default(false)
  isEncrypted Boolean         @default(true)
  isCeoChannel  Boolean       @default(false)
  isBroadcast   Boolean       @default(false)
  departmentId  String?
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastMessageAt DateTime       @default(now())

  // --- TASK-49: Social Messaging Hub extensions (additive) ---
  // Social platform this conversation belongs to (FACEBOOK = Messenger,
  // INSTAGRAM = IG DM, WEBSITE = live chat, future LINKEDIN/WHATSAPP).
  platform           Platform?
  platformAccountId  String?   // CompanySocialAccount id that owns this inbox
  externalId         String?   // platform-native conversation/id (e.g. FB conversation id)
  customerId         String?   // SocialCustomer (external party) for DMs
  priority           ConversationPriority @default(MEDIUM)
  status             ConversationStatus    @default(OPEN)
  labelIds           String[]  @default([]) // ConversationLabel ids
  assignedToId       String?   // denormalized current assignee (see ConversationAssignment)
  // -------------------------------------------------------------------------

  members      ConversationMember[]
  messages     Message[]
  announcements Announcement[]
  customer     SocialCustomer? @relation("CustomerConversations", fields: [customerId], references: [id])
  assignments  ConversationAssignment[]

  @@index([kind])
  @@index([departmentId])
  @@index([isCeoChannel])
  @@index([isArchived])
  @@index([platform])
  @@index([platformAccountId])
  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([updatedAt])
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String   @default("MEMBER")
  isMuted        Boolean  @default(false)
  isFavorite     Boolean  @default(false)
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())
  unreadCount    Int      @default(0)
  typingAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  senderName     String
  content        String
  status         MsgStatus    @default(SENT)
  replyToId      String?
  isEdited       Boolean      @default(false)
  editHistory    Json?
  isDeleted      Boolean      @default(false)
  isPinned       Boolean      @default(false)
  isStarred      Boolean      @default(false)
  isBookmarked   Boolean      @default(false)
  isRecalled     Boolean      @default(false)
  mentions       String[]     @default([])
  translations   Json?
  encryptedContent String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]
  reactions    Reaction[]
  voice        VoiceMessage?
  readReceipts ReadReceipt[]
  forwardedFromMessage Message? @relation("ForwardedFrom", fields: [forwardedFromId], references: [id])
  forwardedFromId String?
  forwardedTo     Message[] @relation("ForwardedFrom")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isPinned])
  @@index([isStarred])
