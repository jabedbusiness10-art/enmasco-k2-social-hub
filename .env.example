# ============================================================
# K2KAI Social Flow — Environment Template (TASK-59)
# Copy to `.env.local` (NEVER commit the real file; it is gitignored).
# `npm run dev` / `next build` reads .env.local first.
# ============================================================

# ---- Core (CRITICAL: app will not run without these) ----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/k2kai?schema=public"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://app.k2kai.com"

# ---- AI (K2Kai AI, TASK-52) ----
AI_PROVIDER="openrouter"
AI_MODEL="tencent/hy3:free"
OPENROUTER_API_KEY="sk-or-..."

# ---- Meta / Facebook / Instagram (TASK-51) ----
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="https://app.k2kai.com/api/auth/callback/meta"
META_WEBHOOK_VERIFY_TOKEN=""

# ---- LinkedIn (TASK-51) ----
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://app.k2kai.com/api/auth/callback/linkedin"

# ---- Google / YouTube (TASK-51) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://app.k2kai.com/api/auth/callback/google"
GOOGLE_ANALYTICS_ID=""

# ---- Queue / BullMQ (TASK-57) ----
# Absent => DB-backed fallback (no background jobs).
REDIS_URL="redis://redis:6379"
QUEUE_SECRET="generate-with: openssl rand -base64 24"

# ---- Media storage (TASK-54/55) ----
# Absent => local ./public/uploads storage.
CLOUDINARY_URL="cloudinary://KEY:SECRET@CLOUD"

# ---- Token encryption at rest ----
# 32-byte base64 key used by services/social/accounts.ts
ENCRYPTION_KEY="generate-with: openssl rand -base64 32"

# ---- SMTP / email (notifications, executive reports) ----
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@k2kai.com"

# ---- Messenger realtime bridge (Socket.IO) ----
NEXT_PUBLIC_MESSENGER_WS="wss://app.k2kai.com"

# ---- Observability ----
NODE_ENV="production"
LOG_LEVEL="info"
