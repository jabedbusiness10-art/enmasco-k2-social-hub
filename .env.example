# ============================================================================
# K2KAI Social Flow — Environment Variables (example)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================================

# --- Database (Prisma) ---
DATABASE_URL=postgresql://USER:PASS@localhost:5432/enmasco_k2_social?schema=public

# --- Auth.js (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# --- K2 Messenger realtime socket ---
NEXT_PUBLIC_MESSENGER_WS=ws://localhost:3001

# --- TASK-45 Meta OAuth (Facebook + Instagram Business) ---
# Get these from https://developers.facebook.com/apps/<APP_ID>/settings
META_APP_ID=replace-with-meta-app-id
META_APP_SECRET=replace-with-meta-app-secret
# Must exactly match the "Valid OAuth Redirect URIs" in the Meta App.
META_REDIRECT_URI=http://localhost:3000/api/social/meta/callback
# Used to verify Meta webhook callbacks (TASK-47/51 webhooks).
META_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-webhook-token
