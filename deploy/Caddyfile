# ============================================================================
# K2KAI Social OS — Caddy reverse proxy (production alternative to NGINX)
# Domain: k2kai.enmasco.com  |  Upstream: pm2 "k2kai-web" on 127.0.0.1:3000
# Caddy auto-obtains + renews TLS (Let's Encrypt) and redirects HTTP -> HTTPS.
# ============================================================================

k2kai.enmasco.com {
    encode zstd gzip

    # Security headers (also set in next.config.mjs; defense-in-depth)
    header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    header X-Content-Type-Options "nosniff"
    header Referrer-Policy "strict-origin-when-cross-origin"

    # Reverse proxy to Next.js (pm2)
    reverse_proxy 127.0.0.1:3000 {
        # WebSocket / SSE / long-polling support
        transport http {
            read_timeout 300s
            write_timeout 300s
        }
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Service worker: never cache
    @sw path /service-worker.js
    rewrite @sw /service-worker.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"
    header @sw Service-Worker-Allowed "/"

    # PWA manifest: 1-day cache
    @manifest path /manifest.webmanifest
    header @manifest Cache-Control "public, max-age=86400"

    # Long-cache Next.js static chunks
    @static path /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"
}
