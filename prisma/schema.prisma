model AssignmentAttachment {
  id           String   @id @default(cuid())
  assignmentId String
  name         String
  url          String
  type         String?  // mime / kind
  uploadedById String
  createdAt    DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

model AssignmentActivity {
  id           String   @id @default(cuid())
  assignmentId String
  actorId      String
  action       String   // CREATED | UPDATED | STATUS | COMMENT | MENTION | COMPLETED | APPROVAL
  meta         String?  @db.Text
  createdAt    DateTime @default(now())

