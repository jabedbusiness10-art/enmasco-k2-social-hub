# ============================================================
# K2KAI Social OS — Environment Template (TASK-67)
# Project: K2KAI Social OS  |  Company: ENMASCO
# Canonical Production URL: https://k2kai.enmasco.com
# ------------------------------------------------------------
# Copy to `.env.local` (NEVER commit the real file; it is gitignored).
# `npm run dev` / `next build` / `pm2` read `.env.local` first.
#
# RULES:
#  - NEVER hardcode credentials or secrets in source code.
#  - EVERY URL below is read from an environment variable at runtime.
#  - The canonical domain is injected via APP_URL / NEXTAUTH_URL only.
#  - OAuth callback URLs are derived from APP_URL (see deploy docs).
# ============================================================

# ---- Branding / Canonical URL ----
# Used by the app, OAuth redirects, emails, and PWA. NO hardcoded URLs in code.
APP_NAME="K2KAI Social OS"
APP_URL="https://k2kai.enmasco.com"
NEXTAUTH_URL="https://k2kai.enmasco.com"

# ---- Core (CRITICAL: app will not run without these) ----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/k2kai?schema=public"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ---- Queue / BullMQ (TASK-57) ----
# Absent => DB-backed fallback (no background jobs). Set for async processing.
REDIS_URL="redis://redis:6379"
QUEUE_SECRET="generate-with: openssl rand -base64 24"

# ---- AI (K2Kai AI, TASK-52) ----
AI_PROVIDER="openrouter"
AI_MODEL="tencent/hy3:free"
OPENAI_API_KEY=""
OPENROUTER_API_KEY="sk-or-..."

# ---- Meta / Facebook (TASK-51) ----
META_APP_ID=""
META_APP_SECRET=""
# Callback is ${APP_URL}/api/auth/callback/meta (do not hardcode localhost)

# ---- Instagram (TASK-51) ----
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
# Callback is ${APP_URL}/api/auth/callback/instagram

# ---- LinkedIn (TASK-51) ----
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://k2kai.enmasco.com/api/social/linkedin/callback"
# Space-delimited and limited to scopes approved on the LinkedIn app's Auth tab.
# Organization publishing typically needs rw_organization_admin,
# r_organization_social and w_organization_social product approval.
LINKEDIN_SCOPES="openid profile email rw_organization_admin r_organization_social w_organization_social"
# Marketing API version in YYYYMM format; review before a LinkedIn version sunsets.
LINKEDIN_API_VERSION="202606"

# ---- Google / YouTube (TASK-51) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Callback is ${APP_URL}/api/auth/callback/google

# ---- Media storage (TASK-54/55) ----
# STORAGE_PROVIDER absent => local ./public/uploads storage.
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
CLOUDINARY_URL="cloudinary://KEY:SECRET@CLOUD"

# ---- Token encryption at rest ----
# 32-byte base64 key used by services/social/accounts.ts
ENCRYPTION_KEY="generate-with: openssl rand -base64 32"
# TOKEN_ENCRYPTION_KEY is accepted as a backwards-compatible alias.

# ---- SMTP / email (notifications, executive reports) ----
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@k2kai.enmasco.com"

# ---- Messenger realtime bridge (Socket.IO) ----
NEXT_PUBLIC_MESSENGER_WS="wss://k2kai.enmasco.com"

# ---- Observability ----
NODE_ENV="production"
LOG_LEVEL="info"
