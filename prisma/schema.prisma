// ---- TASK-53: Enterprise Team Collaboration & Assignments ----
enum AssignmentStatus {
  TODO
  IN_PROGRESS
  REVIEW
  APPROVED
  COMPLETED
  CANCELLED
  OVERDUE
}

enum AssignmentPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AssignmentKind {
  MESSAGE
  COMMENT
  PUBLISHING
  CAMPAIGN
  APPROVAL
  CONTENT_REVIEW
  MEDIA_REVIEW
  CUSTOMER_FOLLOWUP
  SUPPORT_TICKET
  INTERNAL_TASK
}

model Assignment {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  kind         AssignmentKind   @default(INTERNAL_TASK)
  status       AssignmentStatus @default(TODO)
  priority     AssignmentPriority @default(MEDIUM)
  tags         String[]         @default([])
  dueDate      DateTime?
  assignedById String
  assignedToId String
  departmentId String?
  conversationId String?        // linked K2 Messenger / social conversation
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignedBy   User             @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedTo   User             @relation("AssignedTo", fields: [assignedToId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])

  comments     AssignmentComment[]
  attachments  AssignmentAttachment[]
  activities   AssignmentActivity[]
  history      AssignmentHistory[]
  approvalRequests ApprovalRequest[] // TASK-53

  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
  @@index([departmentId])
}

model AssignmentComment {
  id           String   @id @default(cuid())
  assignmentId String
  userId       String
  content      String   @db.Text
  mentions     String[] @default([])  // user ids mentioned via @user
  createdAt    DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId])
