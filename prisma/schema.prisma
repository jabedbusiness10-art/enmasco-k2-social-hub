generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CEO
  ADMIN
  MARKETING_MANAGER
  MARKETING_TEAM
  CONTENT_CREATOR
  ANALYST
  VIEWER
}

enum DepartmentName {
  MARKETING
  SALES
  HR
  FINANCE
  IT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PostStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  APPROVED
  REJECTED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  X
  WEBSITE
}

enum WorkflowStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum NotificationType {
  SYSTEM
  APPROVAL
  AUTOMATION
  AI
  MARKETING
  SECURITY
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

model Role {
  id        String   @id @default(cuid())
  name      UserRole @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Department {
  id          String          @id @default(cuid())
  name        DepartmentName  @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  users User[]
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @relation(fields: [roleId], references: [id])
  roleId        String
  department    Department? @relation(fields: [departmentId], references: [id])
  departmentId  String?
  avatar        String?
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  posts         Post[]
  notifications Notification[]
  auditLogs     AuditLog[]
  conversations AIConversation[]
  scheduledPosts ScheduledPost[]
  workflowJobs  WorkflowJob[]
  aiPrompts     AIPrompt[]
  aiTokenUsages AITokenUsage[]
  mediaAssets   MediaAsset[]
  conversationMembers ConversationMember[]
  conversationNotifications ConversationNotification[]
  assignedConversations ConversationAssignment[] @relation("AssignmentTo")
  createdAssignments     ConversationAssignment[] @relation("AssignmentBy")
  presence     OnlinePresence?

  accounts      Account[]
  sessions      Session[]

  @@index([roleId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
}

model CompanySettings {
  id              String   @id @default(cuid())
  companyId       String?  @unique // TASK-45 pre-flight: loose link to Company model (1:1)
  company         Company? @relation(fields: [companyId], references: [id])
  companyName     String
  companyShortName String?
  logoUrl         String?
  website         String?
  email           String?
  phone           String?
  address         String?
  timezone        String   @default("UTC")
  language        String   @default("en")
  dateFormat      String   @default("DD/MM/YYYY")
  timeFormat      String   @default("24H")
  theme           String   @default("dark")
  accentColor     String   @default("blue")
  sidebarStyle    String   @default("glass")
  glassEffect     Boolean  @default(true)
  sessionTimeout  Int      @default(30)
  passwordPolicy  String   @default("standard")
  auditLogging    Boolean  @default(true)
  supportEmail    String?
  defaultLanguage String   @default("en")
  allowRegistration Boolean @default(true)
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CompanySocialAccount {
  id             String    @id @default(cuid())
  platform       Platform
  accountName    String
  accountHandle  String?
  accountId      String?
  profileUrl     String?
  pageId         String?
  username       String?

  // Encrypted at rest (AES-256-GCM via lib/crypto). Stored as ciphertext strings.
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?

  // --- TASK-45 Meta OAuth extensions (all nullable, non-destructive) ---
  // Instagram Business account linked to the connected Facebook Page.
  instagramBusinessId String?
  // Display name of the selected Facebook Page.
  pageName            String?
  // Granted permission scopes (from token debug / granted_scopes).
  permissions         String[] @default([])
  // High-level token health derived from expiry + debug: ACTIVE | EXPIRED | EXPIRING
  accessTokenStatus   String?  @map("access_token_status")
  // OAuth provider that established this connection (meta | manual | linkedin | ...).
  provider            String?  @default("manual")

  // --- TASK-46 LinkedIn OAuth extensions (all nullable, non-destructive) ---
  // Linkedin Organization (Company Page) identifiers + metadata.
  organizationId    String?  // LinkedIn organization / company page urn id
  organizationName  String?  // display name of the organization
  companyName       String?  // human-readable company name (alias of organizationName)
  companyLogo       String?  // logo URL from LinkedIn
  apiVersion        String?  // LinkedIn API version used (e.g. "202504")
  // -------------------------------------------------------------------------

  status         PlatformStatus @default(CONNECTED)
  connectedBy    String
  connectedById  String?
  lastSyncAt     DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts Post[]

  @@unique([platform, accountHandle])
  @@index([platform])
  @@index([isActive])
}

enum PlatformStatus {
  CONNECTED
  EXPIRING_SOON
  DISCONNECTED
  PERMISSION_ERROR
}

// ===========================================================================
// TASK-47 — Website ↔ Social Hub Integration
// ===========================================================================

enum CmsType {
  WORDPRESS
  NEXTJS
  CUSTOM
  HEADLESS
  LARAVEL
  STATIC
}

enum WebsiteStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

model WebsiteConnection {
  id            String   @id @default(cuid())
  companyId     String?
  websiteName   String
  websiteUrl    String
  cmsType       CmsType  @default(CUSTOM)
  // Encrypted at rest (AES-256-GCM via lib/crypto). Stored as ciphertext.
  apiKey        String
  webhookSecret String
  status        WebsiteStatus @default(CONNECTED)
  // Health signals (live, recomputed on test/status).
  online        Boolean  @default(true)
  sslValid      Boolean  @default(true)
  apiStatus     Boolean  @default(true)
  webhookStatus Boolean  @default(true)
  lastSync      DateTime?
  syncFrequency String   @default("MANUAL") // MANUAL | HOURLY | DAILY | REALTIME
  connectedBy   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

enum MediaStatus {
  ACTIVE
  ARCHIVED
  TRASHED
}

model MediaFolder {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  icon      String? // lucide icon name
  parentId  String?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  parent    MediaFolder? @relation("FolderChildren", fields: [parentId], references: [id])
  children  MediaFolder[] @relation("FolderChildren")
  assets    MediaAsset[]

  @@index([parentId])
}

model MediaAsset {
  id            String      @id @default(cuid())
  fileName      String
  originalName  String
  fileType      String // IMAGE | VIDEO | DOCUMENT | LOGO | BRAND_ASSET
  mimeType      String
  fileSize      Int
  cloudinaryId  String // storage key / provider id (Cloudinary/S3 ready)
  url           String
  width         Int?
  height        Int?
  duration      Float? // seconds, for video/audio
  extension     String? // jpg, mp4, pdf ...
  category      String?
  tags          String[]
  description   String?
  status        MediaStatus @default(ACTIVE)
  favorited     Boolean     @default(false)
  usageCount    Int         @default(0)
  lastUsedAt    DateTime?
  uploadedBy    String
  uploadedById  String?
  folderId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  archivedAt    DateTime?

  folder      MediaFolder? @relation(fields: [folderId], references: [id])
  uploadedUser User?       @relation(fields: [uploadedById], references: [id])
  activities  MediaActivity[]

  @@index([fileType])
  @@index([category])
  @@index([folderId])
  @@index([status])
  @@index([uploadedById])
  @@index([createdAt])
}

model MediaActivity {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  userName  String
  action    String // UPLOAD | RENAME | DELETE | MOVE | DOWNLOAD | SHARE | ARCHIVE | RESTORE | FAVORITE
  meta      String? // free text / extra info
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([createdAt])
}

model Campaign {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String?
  budget      Float?
  createdById String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts Post[]
}

model Post {
  id            String    @id @default(cuid())
  content       String?
  mediaUrl      String?
  platform      Platform
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  campaignId    String?
  createdById   String
  accountId     String?
  tags          String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign   Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  account    CompanySocialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creator    User                 @relation(fields: [createdById], references: [id])
  scheduled  ScheduledPost?
  platforms  PostPlatform[]
  media      PostMedia[]
  jobs       PublishingJob[]
  history    PublishingHistory[]
  approvals  Approval[]

  // TASK-48 — composer fields
  title       String?
  link        String?
  cta         String?
  location    String?
  hashtags    String[] @default([])

  @@index([platform])
  @@index([status])
  @@index([campaignId])
  @@index([accountId])
  @@index([createdById])
  @@index([publishedAt])
  @@index([createdAt])
}

model ScheduledPost {
  id              String    @id @default(cuid())
  postId          String    @unique
  scheduledAt     DateTime
  priority        String?
  retryCount      Int       @default(0)
  lastError       String?
  status          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  owner           User?     @relation(fields: [ownerId], references: [id])
  ownerId         String?

  @@index([scheduledAt])
  @@index([status])
}

// ===========================================================================
// TASK-48 — Enterprise Real Publishing Engine
// ===========================================================================

enum PublishStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum JobState {
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  RETRY
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QueueState {
  QUEUED
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

model PostPlatform {
  id           String       @id @default(cuid())
  postId       String
  platform     Platform // FACEBOOK | INSTAGRAM | LINKEDIN (also X/TIKTOK/YOUTUBE future)
  accountId    String? // CompanySocialAccount id (the connected page/company)
  status       PublishStatus @default(QUEUED)
  platformPostId String? // id returned by the platform after publish
  liveUrl      String? // permalink to the published post
  error        String?
  mediaIds     String[] // PostMedia ids used for this platform
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([postId])
  @@index([platform])
  @@index([status])
}

model PostMedia {
  id         String @id @default(cuid())
  postId     String
  type       String // IMAGE | VIDEO | CAROUSEL | DOCUMENT | LINK
  url        String
  thumbnail  String?
  alt        String?
  order      Int    @default(0)
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PublishingJob {
  id            String   @id @default(cuid())
  postId        String
  platform      Platform
  accountId     String?
  state         JobState @default(QUEUED)
  scheduledFor  DateTime? // when to publish (null = now)
  startedAt     DateTime?
  finishedAt    DateTime?
  attempt       Int      @default(0)
  maxAttempts   Int      @default(3)
  lastError     String?
  resultPostId  String?
  resultUrl     String?
  queueId       String? // links to Queue row (DB-backed or BullMQ job id)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([scheduledFor])
  @@index([postId])
}

model PublishingHistory {
  id           String   @id @default(cuid())
  postId       String
  platform     Platform
  accountId    String?
  status       PublishStatus
  postPlatformId String?
  publishedBy  String
  publishedAt  DateTime @default(now())
  platformPostId String?
  liveUrl      String?
  errorMessage String?
  jobId        String?
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([platform])
  @@index([status])
  @@index([publishedAt])
}

model Approval {
  id         String        @id @default(cuid())
  postId     String
  status     ApprovalStatus @default(PENDING)
  requestedBy String
  reviewedBy  String?
  reviewedAt  DateTime?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId])
  @@index([postId])
  @@index([status])
}

model Queue {
  id          String    @id @default(cuid())
  name        String // e.g. "publishing"
  payload     String // JSON (serialized job), encrypted if sensitive
  state       QueueState @default(QUEUED)
  priority    Int       @default(0)
  runAt       DateTime  @default(now()) // earliest run time (for scheduled)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  lockedUntil DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([state])
  @@index([runAt])
  @@index([name])
}

// ===========================================================================
// K2 MESSENGER  (TASK-44) — enums
// ===========================================================================

enum ConversationKind {
  DIRECT
  GROUP
  CHANNEL
  DEPARTMENT
  ANNOUNCEMENT
  CEO_BROADCAST
  COMPANY_BROADCAST
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  BUSY
  AWAY
  DND
}

enum MsgStatus {
  SENT
  DELIVERED
  READ
}

enum AttachmentKind {
  IMAGE
  VIDEO
  AUDIO
  PDF
  WORD
  EXCEL
  POWERPOINT
  ZIP
  OTHER
}

enum ReactionEmoji {
  LIKE
  HEART
  FIRE
  CLAP
  LAUGH
  WOW
  CRY
  PARTY
}

model Conversation {
  id          String          @id @default(cuid())
  kind        ConversationKind
  title       String?
  description String?
  avatarUrl   String?
  isPinned    Boolean         @default(false)
  isStarred   Boolean         @default(false)
  isArchived  Boolean         @default(false)
  isEncrypted Boolean         @default(true)
  isCeoChannel  Boolean       @default(false)
  isBroadcast   Boolean       @default(false)
  departmentId  String?
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastMessageAt DateTime       @default(now())

  // --- TASK-49: Social Messaging Hub extensions (additive) ---
  // Social platform this conversation belongs to (FACEBOOK = Messenger,
  // INSTAGRAM = IG DM, WEBSITE = live chat, future LINKEDIN/WHATSAPP).
  platform           Platform?
  platformAccountId  String?   // CompanySocialAccount id that owns this inbox
  externalId         String?   // platform-native conversation/id (e.g. FB conversation id)
  customerId         String?   // SocialCustomer (external party) for DMs
  priority           ConversationPriority @default(MEDIUM)
  status             ConversationStatus    @default(OPEN)
  labelIds           String[]  @default([]) // ConversationLabel ids
  assignedToId       String?   // denormalized current assignee (see ConversationAssignment)
  // -------------------------------------------------------------------------

  members      ConversationMember[]
  messages     Message[]
  announcements Announcement[]
  customer     SocialCustomer? @relation("CustomerConversations", fields: [customerId], references: [id])
  assignments  ConversationAssignment[]

  @@index([kind])
  @@index([departmentId])
  @@index([isCeoChannel])
  @@index([isArchived])
  @@index([platform])
  @@index([platformAccountId])
  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([updatedAt])
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String   @default("MEMBER")
  isMuted        Boolean  @default(false)
  isFavorite     Boolean  @default(false)
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())
  unreadCount    Int      @default(0)
  typingAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  senderName     String
  content        String
  status         MsgStatus    @default(SENT)
  replyToId      String?
  isEdited       Boolean      @default(false)
  editHistory    Json?
  isDeleted      Boolean      @default(false)
  isPinned       Boolean      @default(false)
  isStarred      Boolean      @default(false)
  isBookmarked   Boolean      @default(false)
  isRecalled     Boolean      @default(false)
  mentions       String[]     @default([])
  translations   Json?
  encryptedContent String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]
  reactions    Reaction[]
  voice        VoiceMessage?
  readReceipts ReadReceipt[]
  forwardedFromMessage Message? @relation("ForwardedFrom", fields: [forwardedFromId], references: [id])
  forwardedFromId String?
  forwardedTo     Message[] @relation("ForwardedFrom")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isPinned])
  @@index([isStarred])
}

model Attachment {
  id            String        @id @default(cuid())
  messageId     String
  kind          AttachmentKind
  fileName      String
  originalName  String
  mimeType      String
  fileSize      Int
  url           String
  thumbnailUrl  String?
  duration      Float?
  encryptedUrl  String?
  createdAt     DateTime      @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model VoiceMessage {
  id        String  @id @default(cuid())
  messageId String  @unique
  url       String
  duration  Float
  transcript String?
  waveform  Float[] @default([])
  encryptedUrl String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id          String        @id @default(cuid())
  messageId   String
  userId      String
  emoji       ReactionEmoji
  createdAt   DateTime      @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ReadReceipt {
  id          String     @id @default(cuid())
  messageId   String
  userId      String
  status      MsgStatus  @default(DELIVERED)
  at          DateTime   @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model Announcement {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String
  authorName     String
  title          String
  body           String
  priority       String   @default("NORMAL")
  audience       String   @default("ALL")
  departmentId   String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([priority])
  @@index([createdAt])
}

// ===========================================================================
// TASK-49 — Enterprise Direct Message Center (Social Messaging Hub)
// Extends the existing K2 Messenger Conversation with social-platform
// identity, CRM-style fields, labels, assignment and status tracking.
// All additions are additive + nullable where sensible (non-destructive).
// ===========================================================================

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ConversationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// External social customer identity (Facebook/Instagram user, website visitor,
// future WhatsApp/LinkedIn). Distinct from internal User.
model SocialCustomer {
  id            String   @id @default(cuid())
  platform      Platform?
  externalId    String?  // platform-scoped user id (psid / ig id / wa id)
  firstName     String?
  lastName      String?
  name          String // display name fallback
  avatarUrl     String?
  locale        String?  @default("en")
  // Conversation(s) this customer participates in (direct DMs)
  conversations Conversation[] @relation("CustomerConversations")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([platform])
  @@index([externalId])
}

// Reusable conversation labels (e.g. "Lead", "Complaint", "VIP").
model ConversationLabel {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#38bdf8") // hex token, no magic UI change
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Assignment of a conversation to an internal team member.
model ConversationAssignment {
  id             String   @id @default(cuid())
  conversationId String
  assignedToId    String // User id
  assignedById    String?
  assignedAt      DateTime @default(now())
  note            String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedTo   User        @relation("AssignmentTo", fields: [assignedToId], references: [id])
  assignedBy   User?       @relation("AssignmentBy", fields: [assignedById], references: [id])

  @@index([conversationId])
  @@index([assignedToId])
}

// ===========================================================================
// TASK-45 Pre-Flight — DB readiness models (additive, non-destructive)
model ConversationNotification {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  messageId      String?
  type           String
  title          String
  body           String?
  isRead         Boolean  @default(false)
  priority       String   @default("NORMAL")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model OnlinePresence {
  userId     String        @id
  status     PresenceStatus @default(ONLINE)
  lastSeen   DateTime      @default(now())
  socketId   String?
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String              @id @default(cuid())
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  title     String
  body      String?
  isRead    Boolean             @default(false)
  meta      String?
  createdAt DateTime            @default(now())
  userId    String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model Workflow {
  id          String    @id @default(cuid())
  name        String
  description String?
  isEnabled   Boolean   @default(true)
  trigger     String?
  action      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobs WorkflowJob[]

  @@index([isEnabled])
}

model WorkflowJob {
  id            String       @id @default(cuid())
  workflowId    String
  status        WorkflowStatus @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?
  createdById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workflow      Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  createdBy     User?        @relation(fields: [createdById], references: [id])

  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
}

model AIConversation {
  id        String    @id @default(cuid())
  module    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String

  user      User       @relation(fields: [userId], references: [id])
  messages  AIMessage[]

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

model AIMessage {
  id              String    @id @default(cuid())
  conversationId  String
  role            String
  content         String
  tokensUsed      Int?
  createdAt       DateTime  @default(now())

  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AIPrompt {
  id          String   @id @default(cuid())
  title       String
  prompt      String
  category    String   @default("General")
  favorite    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([category])
}

model AITokenUsage {
  id            String   @id @default(cuid())
  userId        String
  conversationId String?
  module        String
  promptTokens  Int      @default(0)
  completionTokens Int   @default(0)
  totalTokens   Int      @default(0)
  model         String
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model AISettings {
  id            String   @id @default("singleton")
  model         String   @default("k2kai-demo")
  provider      String   @default("mock")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(1024)
  streaming     Boolean  @default(true)
  systemPrompt  String   @default("You are K2Kai, the enterprise AI copilot for ENMASCO K2 SOCIAL.")
  defaultLanguage String @default("en")
  knowledgeEnabled Boolean @default(true)
  safetyMode    Boolean @default(true)
  debugMode     Boolean @default(false)
  updatedAt     DateTime @updatedAt
}

// ---- TASK-52: Company Knowledge Base ----
model KnowledgeCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  documents   KnowledgeDocument[]
  createdAt   DateTime @default(now())
}

model KnowledgeDocument {
  id         String   @id @default(cuid())
  category   KnowledgeCategory @relation(fields: [categoryId], references: [id])
  categoryId String
  title      String
  content    String   @db.Text
  source     String?  // e.g. "Product Catalog", "Warranty Policy"
  tags       String[] @default([])
  isPublished Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
  @@index([isPublished])
}


model Analytics {
  id           String    @id @default(cuid())
  module       String
  metric       String
  value        Float?
  dimension    String?
  recordedAt   DateTime  @default(now())

  @@index([module])
  @@index([metric])
  @@index([recordedAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entityName String?
  entityId   String?
  oldValue   String?
  newValue   String?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  createdById String

  createdBy  User      @relation(fields: [createdById], references: [id])

  @@index([entityName])
  @@index([entityId])
  @@index([createdById])
  @@index([createdAt])
}

// ============================================================================
// TASK-45 Pre-Flight — DB readiness models (additive, non-destructive)
// ============================================================================

// Company entity (Blueprint: Administration > Company Settings).
// Loose 1:1 with CompanySettings via optional companyId on CompanySettings.
model Company {
  id           String   @id @default(cuid())
  name         String
  legalName    String?
  website      String?
  industry     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings CompanySettings?
}

// --- NextAuth.js OAuth adapter tables (readiness for TASK-46 LinkedIn OAuth) ---
// Standard next-auth models. Stored provider OAuth identities link here.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
